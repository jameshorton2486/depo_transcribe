**(2).docx

# Training corpus — real client transcripts contain PII and never get
# committed. Only the workflow README and the .gitkeep are tracked, so
# the directory exists in the repo but case folders stay local.
training_corpus/*
!training_corpus/README.md
!training_corpus/.gitkeep

# Local tool/IDE config dropped inside the reference-PDF directory.
# The PDFs themselves are tracked as design references for the
# ufm_engine/templates/figures/*.docx generators.
ufm_template/settings.local.json
prompt_HEAD.txt
